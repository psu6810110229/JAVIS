# Jarvis Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables have sensible defaults; you only need to override what changes.

# ─── LLM Models ──────────────────────────────────────────────────────────────
# Performance mode: larger model, higher quality, ~8GB RAM
JARVIS_MODEL_PERFORMANCE=scb10x/llama3.1-typhoon2-8b-instruct

# Eco mode: lighter model, lower RAM, faster (auto-activated under memory pressure)
JARVIS_MODEL_ECO=scb10x/typhoon2.5-qwen3-4b

# ─── Ollama Connection ────────────────────────────────────────────────────────
# URL of the Ollama service (within Docker network)
OLLAMA_BASE_URL=http://ollama:11434

# Enable Intel iGPU acceleration via Vulkan/oneAPI (0 = CPU only)
OLLAMA_INTEL_GPU=0

# Cap loaded models to 1 (critical for 16GB RAM)
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1

# Keep model resident in memory (-1 = forever)
OLLAMA_KEEP_ALIVE=-1

# ─── TTS Configuration ────────────────────────────────────────────────────────
# Backend mode: 'dml-host' (Windows ONNX worker) or 'cpu-service' (Docker container)
JARVIS_TTS_BACKEND_MODE=dml-host

# Primary TTS endpoint (DML worker on Windows host)
JARVIS_TTS_URL=http://host.docker.internal:8870/v1/audio/speech

# Fallback TTS endpoint (CPU Kokoro container)
JARVIS_TTS_FALLBACK_URL=http://kokoro:8880/v1/audio/speech

# Speech rate (0.7–1.6, default 1.2)
JARVIS_TTS_SPEED=1.2

# TTS request timeout in seconds
JARVIS_TTS_TIMEOUT_SECONDS=60

# ─── Host Optimizer (Standby List Flusher) ────────────────────────────────────
# URL of the Windows-side optimizer listener (empty = disabled)
# Start with: scripts/start-jarvis-with-priorities.ps1 -StartHostOptimizer
JARVIS_HOST_OPTIMIZER_URL=http://host.docker.internal:8765/optimize

# Max time to wait for optimizer before proceeding (seconds)
JARVIS_HOST_OPTIMIZER_TIMEOUT_SECONDS=0.35

# ─── Phase 4: Windows Machine Agent ──────────────────────────────────────────
# Comma-separated exe names Jarvis cannot open (e.g. regedit.exe,taskkill.exe)
JARVIS_APP_BLOCKLIST=

# Directory where screenshots are saved (default: %USERPROFILE%\Pictures\Jarvis)
JARVIS_SCREENSHOT_DIR=

# Seconds to wait for an app to show a window before reporting timeout (default 10)
JARVIS_APP_LAUNCH_TIMEOUT=10

# ─── Spotify Integration ──────────────────────────────────────────────────────
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_SCOPE=user-read-playback-state user-modify-playback-state user-read-currently-playing
